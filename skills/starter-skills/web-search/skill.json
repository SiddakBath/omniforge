        "properties": {
          "query": { "type": "string" },
          "limit": { "type": "number", "default": 5 },
          "count": { "type": "number" },
          "mode": { "type": "string", "enum": ["auto", "api", "builtin"], "default": "auto" },
          "search_mode": { "type": "string", "enum": ["auto", "api", "builtin"] },
          "provider": { "type": "string", "enum": ["brave", "perplexity", "gemini", "grok", "xai", "kimi", "moonshot"] },
          "country": { "type": "string" },
          "language": { "type": "string" },
          "freshness": { "type": "string" },
          "date_after": { "type": "string" },
          "date_before": { "type": "string" },
          "domain_filter": {
            "oneOf": [
              { "type": "string" },
              { "type": "array", "items": { "type": "string" } }
