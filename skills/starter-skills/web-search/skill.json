          },
          "model": { "type": "string" },
          "base_url": { "type": "string" },
          "timeout_ms": { "type": "number", "default": 15000 },
          "api_key": { "type": "string", "description": "Generic provider key override." },
          "brave_api_key": { "type": "string" },
          "perplexity_api_key": { "type": "string" },
          "gemini_api_key": { "type": "string" },
          "xai_api_key": { "type": "string" },
          "grok_api_key": { "type": "string" },
          "kimi_api_key": { "type": "string" },
          "moonshot_api_key": { "type": "string" }
        },
        "required": ["query"]
      }
    }
  ],
  "requiredParams": [],
