{
  "id": "web-search",
  "name": "Web Search",
  "description": "Searches the web and returns ranked snippets.",
  "instruction": "Use this tool when you need fresh web information. Provide a concise query and prefer authoritative sources.",
  "tools": [
    {
      "name": "web_search",
      "description": "Search the web via classic APIs or model built-in search",
      "handler": "runTool",
      "parameters": {
